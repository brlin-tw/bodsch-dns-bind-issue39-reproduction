; Initial zone file -- what a FIRST deployment templates onto disk.
; Low serial; named loads this cleanly, then a dynamic update bumps it.
;
; Copyright 2026 Buo-ren Lin (OSSII) <buoren.lin@ossii.com.tw>
; SPDX-License-Identifier: AGPL-3.0-or-later
$TTL 600
@   IN SOA ns.repro.test. admin.repro.test. (
            1          ; serial
            60         ; refresh
            60         ; retry
            604800     ; expire
            10 )       ; minimum
    IN NS  ns.repro.test.
ns  IN A   127.0.0.1
